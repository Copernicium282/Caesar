{
  "manifest_version": 3,
  "name": "Caesar",
  "description": "Blockchain-verified password manager",
  "version": "0.1.0",
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "action": { "default_popup": "index.html", "default_icon": "icons/icon-32.png", "default_title": "Caesar" },
  "permissions": ["clipboardWrite", "storage", "tabs", "contextMenus", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:9876/*"],
  "background": { "scripts": ["background.js"], "type": "module" },
  "content_scripts": [{ "matches": ["*://*/*"], "js": ["content/fill.js"], "run_at": "document_idle" }]
}
